{
  "name": "advance-web-pos-backend",
  "version": "1.0.0",
  "description": "Multi-Tenant POS + Inventory + Accounting ERP System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:master": "npx sequelize-cli db:migrate --config src/config/database.js --migrations-path src/database/migrations/master",
    "migrate:client": "npx sequelize-cli db:migrate --config src/config/database.js --migrations-path src/database/migrations/client",
    "seed:superadmin": "npx sequelize-cli db:seed --config src/config/database.js --seeders-path src/database/seeders"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.0",
    "mysql2": "^3.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "xss-clean": "^0.1.1",
    "express-rate-limit": "^7.1.4",
    "pdfkit": "^0.13.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1"
  }
}
